// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id              String            @id @default(cuid())
  name            String
  address         String?
  phone           String?
  email           String?
  users           User[]
  accounts        Account[]
  journals        JournalEntry[]
  isActive        Boolean           @default(true)
  isDeleted       Boolean           @default(false)
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime?
  createBy        String?
  updateBy        String?
  role            Role[]
  rolePermisions  RolePermision[]
  auditlog        auditlog[]
  lang            Lang[]
  menu            Menu[]
  menuType        MenuType[]
  menuTranslation MenuTranslation[]
  mediaPage       MediaPage[]
  page            Page[]
  pageCategory    PageCategory[]
  pageTranslation PageTranslation[]
  wordingPage     WordingPage[]
  wordingGeneral  WordingGeneral[]
  settingApp      SettingApp[]
  category        Category[]
  template        Template[]
  section         Section[]
  media           Media[]
  customer        Customer[]
  vendor          Vendor[]
  invoice         Invoice[]
  payment         Payment[]
  accountBalances AccountBalance[]
  typeTransaction TypeTransaction[]
  businessPartner BusinessPartner[]
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  name       String
  companyId  String?
  company    Company?  @relation(fields: [companyId], references: [id])
  roleId     Int
  role       Role      @relation(fields: [roleId], references: [id])
  token      String? // opsional, bisa untuk menyimpan token
  tokenAt    DateTime? @default(now())
  updateAt   DateTime  @default(now())
  createdAt  DateTime  @default(now())
  isActive   Boolean   @default(true)
  isDeleted  Boolean   @default(false)
  isLogin    Boolean   @default(false)
  loginDate  DateTime?
  logOutDate DateTime?
  deletedAt  DateTime?
  createBy   String?
  updateBy   String?
  lang       Lang?     @relation(fields: [langCode], references: [code])
  langCode   String?
}

model Role {
  id         Int             @id @default(autoincrement())
  name       String          @unique
  companyId  String?
  company    Company?        @relation(fields: [companyId], references: [id])
  users      User[]
  permisions RolePermision[]
  isActive   Boolean         @default(true)
  isDeleted  Boolean         @default(false)
  deletedAt  DateTime?
  updateAt   DateTime        @default(now())
  createdAt  DateTime        @default(now())
  createBy   String?
  updateBy   String?
}

model RolePermision {
  id        Int       @id @default(autoincrement())
  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id])
  roleId    Int
  role      Role      @relation(fields: [roleId], references: [id])
  menuId    Int
  menu      Menu      @relation(fields: [menuId], references: [id])
  view      Boolean   @default(false)
  create    Boolean   @default(true)
  update    Boolean   @default(false)
  deleted   Boolean   @default(false)
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  updateAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  createBy  String?
  updateBy  String?
}

model auditlog {
  id        Int      @id @default(autoincrement())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  userId    Int
  user      String
  ip        String
  urlApi    String
  urlFe     String
  methodApi String
  bodyApi   String
  menuId    Int
  menuLabel String
  pageId    Int
  PageLabel String
  createBy  String
  updateBy  String
  updateAt  DateTime @default(now())
  createdAt DateTime @default(now())
}

model Lang {
  code             String            @id
  name             String
  companyId        String?
  company          Company?          @relation(fields: [companyId], references: [id])
  isActive         Boolean           @default(true)
  isDeleted        Boolean           @default(false)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createBy         String?
  updateBy         String?
  menuTranslations MenuTranslation[]
  pageTranslations PageTranslation[]
  sections         Section[]
  pageCategory     PageCategory[]
  wording          WordingPage[]
  user             User[]
}

model Media {
  id        Int       @id @default(autoincrement())
  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id])
  menuId    Int
  type      String
  langCode  String
  url       String // URL bisa beda per bahasa
  alt       String?
  title     String?
  menu      Menu      @relation(fields: [menuId], references: [id])
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createBy  String?
  updateBy  String?

  @@unique([menuId, type, langCode])
}

model Menu {
  id             Int               @id @default(autoincrement())
  companyId      String?
  company        Company?          @relation(fields: [companyId], references: [id])
  parentId       Int?
  parent         Menu?             @relation("MenuToSub", fields: [parentId], references: [id])
  children       Menu[]            @relation("MenuToSub")
  order          Int               @default(0)
  isActive       Boolean           @default(true)
  sort           Int               @default(0)
  publishAt      DateTime?         @default(now())
  unPublishAt    DateTime?
  medias         Media[]
  typeMenuId     Int?
  typeMenu       MenuType?         @relation(fields: [typeMenuId], references: [id])
  isDeleted      Boolean           @default(false)
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime?
  createBy       String?
  updateBy       String?
  translations   MenuTranslation[]
  rolePermisions RolePermision[]
}

model MenuType {
  id        Int       @id @default(autoincrement())
  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id])
  name      String
  slug      String?
  menus     Menu[]
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  updateAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  createBy  String?
  updateBy  String?
}

model MenuTranslation {
  id          Int       @id @default(autoincrement())
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id])
  menuId      Int
  langCode    String
  title       String
  subTitle    String?
  linkType    LinkType? @default(URL)
  slug        String?
  pageId      Int?
  categoryId  Int?
  description String?
  overview    String?
  category    Category? @relation(fields: [categoryId], references: [id])
  page        Page?     @relation(fields: [pageId], references: [id])
  menu        Menu      @relation(fields: [menuId], references: [id])
  lang        Lang      @relation(fields: [langCode], references: [code])
  isActive    Boolean   @default(true)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?
  createBy    String?
  updateBy    String?

  @@unique([menuId, langCode])
}

enum PageType {
  POST
  PAGE
}

enum LinkType {
  URL
  PAGE
  CATEGORY
}

model MediaPage {
  id         Int       @id @default(autoincrement())
  companyId  String?
  company    Company?  @relation(fields: [companyId], references: [id])
  pageId     Int?
  categoryId Int?
  type       String
  langCode   String
  url        String // URL bisa beda per bahasa
  alt        String?
  title      String?
  menu       Page?     @relation(fields: [pageId], references: [id])
  category   Category? @relation(fields: [categoryId], references: [id])
  isActive   Boolean   @default(true)
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createBy   String?
  updateBy   String?

  @@unique([pageId, type, langCode])
}

model Page {
  id               Int               @id @default(autoincrement())
  companyId        String?
  company          Company?          @relation(fields: [companyId], references: [id])
  pageType         PageType          @default(PAGE)
  order            Int               @default(0)
  sort             Int               @default(0)
  publishAt        DateTime?         @default(now())
  unPublishAt      DateTime?
  mediaPages       MediaPage[]
  isActive         Boolean           @default(true)
  isDeleted        Boolean           @default(false)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime?
  createBy         String?
  updateBy         String?
  translations     PageTranslation[]
  menuTranslations MenuTranslation[]
  sectionsAsMain   Section[]         @relation("PageAsMain")
  sectionsAsData   Section[]         @relation("PageAsData")
  pageCategories   PageCategory[]
  wording          WordingPage[]
}

model PageCategory {
  id         Int       @id @default(autoincrement())
  companyId  String?
  company    Company?  @relation(fields: [companyId], references: [id])
  pageId     Int
  page       Page?     @relation(fields: [pageId], references: [id])
  categoryId Int?
  categories Category? @relation(fields: [categoryId], references: [id])
  langCode   String?
  lang       Lang?     @relation(fields: [langCode], references: [code])
}

model PageTranslation {
  id              Int       @id @default(autoincrement())
  companyId       String?
  company         Company?  @relation(fields: [companyId], references: [id])
  pageId          Int?
  categoryId      Int?
  view            Int       @default(0)
  langCode        String
  title           String
  subTitle        String?
  slug            String?
  description     String?
  overview        String?
  metaTitle       String? // Title untuk tag <title>
  metaDescription String? // Untuk tag <meta name="description">
  metaKeywords    String? // Untuk tag <meta name="keywords"> (meskipun jarang digunakan)
  ogTitle         String? // Untuk tag <meta property="og:title">
  ogDescription   String? // Untuk tag <meta property="og:description">
  ogImage         String? // Untuk tag <meta property="og:image">
  ogType          String? // Untuk tag <meta property="og:type">
  canonicalUrl    String? // Untuk tag <link rel="canonical">
  page            Page?     @relation(fields: [pageId], references: [id])
  category        Category? @relation(fields: [categoryId], references: [id])
  lang            Lang      @relation(fields: [langCode], references: [code])
  isActive        Boolean   @default(true)
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime?
  createBy        String?
  updateBy        String?

  @@unique([pageId, langCode])
}

model WordingPage {
  companyId        String?
  company          Company?        @relation(fields: [companyId], references: [id])
  id               Int             @id @default(autoincrement())
  wordingGeneralId Int?
  wordingGeneral   WordingGeneral? @relation(fields: [wordingGeneralId], references: [id])
  key              String
  label            String
  langCode         String
  lang             Lang            @relation(fields: [langCode], references: [code])
  page             Page?           @relation(fields: [pageId], references: [id])
  pageId           Int?
  isActive         Boolean         @default(true)
  isDeleted        Boolean         @default(false)
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime?
  createBy         String?
  updateBy         String?
}

model WordingGeneral {
  companyId   String?
  company     Company?      @relation(fields: [companyId], references: [id])
  id          Int           @id @default(autoincrement())
  key         String
  isActive    Boolean       @default(true)
  isDeleted   Boolean       @default(false)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime?
  createBy    String?
  updateBy    String?
  WordingPage WordingPage[]
}

model SettingApp {
  id        Int       @id @default(autoincrement())
  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id])
  key       String
  value     String?
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime?
  createBy  String?
  updateBy  String?
}

model Category {
  id               Int               @id @default(autoincrement())
  companyId        String?
  company          Company?          @relation(fields: [companyId], references: [id])
  pageTranslations PageTranslation[]
  medias           MediaPage[]
  sections         Section[]
  isActive         Boolean           @default(true)
  isDeleted        Boolean           @default(false)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime?
  createBy         String?
  updateBy         String?
  menuTranslations MenuTranslation[]
  pageCategories   PageCategory[]
}

model Template {
  id        Int       @id @default(autoincrement())
  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id])
  name      String
  code      String
  sections  Section[]
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime?
  createBy  String?
  updateBy  String?
}

enum SectionType {
  CONTENT
  CATEGORY
  PAGE
}

model Section {
  id          Int         @id @default(autoincrement())
  companyId   String?
  company     Company?    @relation(fields: [companyId], references: [id])
  type        SectionType
  order       Int         @default(0)
  pageId      Int
  page        Page        @relation("PageAsMain", fields: [pageId], references: [id])
  pageIdData  Int?
  pageData    Page?       @relation("PageAsData", fields: [pageIdData], references: [id])
  categoryId  Int?
  category    Category?   @relation(fields: [categoryId], references: [id])
  templateId  Int
  template    Template    @relation(fields: [templateId], references: [id])
  langCode    String
  lang        Lang        @relation(fields: [langCode], references: [code])
  title       String?
  subTitle    String?
  image       String?
  secondImage String?
  slug        String?
  description String?
  overview    String?
  isActive    Boolean     @default(true)
  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime?
  createBy    String?
  updateBy    String?
}

enum CashFlowCategory {
  OPERATING
  INVESTING
  FINANCING
}

model Account {
  id               String            @id @default(cuid())
  companyId        String
  company          Company           @relation(fields: [companyId], references: [id])
  code             String // contoh: 1001, 2001, dsb.
  name             String
  type             AccountType
  cashFlowCategory CashFlowCategory?
  parentId         String? // untuk nested akun (misal Kas → Kas Kecil, Kas Besar)
  parent           Account?          @relation("AccountHierarchy", fields: [parentId], references: [id])
  children         Account[]         @relation("AccountHierarchy")
  journalLines     JournalLine[]
  payment          Payment[]
  accountBalances  AccountBalance[]
  debitTypes       TypeTransaction[] @relation("DebitAccount")
  creditTypes      TypeTransaction[] @relation("CreditAccount")
  isActive         Boolean           @default(true)
  isDeleted        Boolean           @default(false)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime?
  createBy         String?
  updateBy         String?
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum StatusJournal {
  DRAFT
  POSTED
}

model JournalEntry {
  id                String           @id @default(cuid())
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])
  businessPartnerId String?
  businessPartners  BusinessPartner? @relation(fields: [businessPartnerId], references: [id])
  date              DateTime
  description       String
  reference         String? // no. transaksi, invoice, dll
  lines             JournalLine[]
  source            SourceJournal
  statusJournal     StatusJournal?   @default(DRAFT)
  isActive          Boolean          @default(true)
  isDeleted         Boolean          @default(false)
  deletedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime?
  createBy          String?
  updateBy          String?
  invoice           Invoice[]
  typeTransactionId String?
  typeTransaction   TypeTransaction? @relation(fields: [typeTransactionId], references: [id])
}

enum SourceJournal {
  JOURNALENTRY
  TRANSACTIONENTRY
  PAYMENT
  INVOICE
}

model JournalLine {
  id          String       @id @default(cuid())
  journalId   String
  description String?
  journal     JournalEntry @relation(fields: [journalId], references: [id])
  accountId   String
  account     Account      @relation(fields: [accountId], references: [id])
  debit       Decimal      @default(0.0)
  credit      Decimal      @default(0.0)
  isActive    Boolean      @default(true)
  isDeleted   Boolean      @default(false)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime?
  createBy    String?
  updateBy    String?
}

model Customer {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  email     String?
  phone     String?
  address   String?
  invoices  Invoice[]
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime?
  createBy  String?
  updateBy  String?
}

model Vendor {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  email     String?
  phone     String?
  address   String?
  invoices  Invoice[]
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime?
  createBy  String?
  updateBy  String?
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  CANCELLED
}

model Payment {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  invoiceId String?
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id])
  date      DateTime
  amount    Decimal
  accountId String // link ke COA (Kas, Bank, dll)
  account   Account   @relation(fields: [accountId], references: [id])
  reference String?
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime?
  createBy  String?
  updateBy  String?
}

model Invoice {
  id         String        @id @default(cuid())
  companyId  String
  company    Company       @relation(fields: [companyId], references: [id])
  customerId String?
  customer   Customer?     @relation(fields: [customerId], references: [id])
  vendorId   String?
  vendor     Vendor?       @relation(fields: [vendorId], references: [id])
  number     String        @unique
  date       DateTime
  dueDate    DateTime?
  status     InvoiceStatus @default(DRAFT)
  total      Decimal       @default(0.0)
  payments   Payment[]
  journalId  String?
  journal    JournalEntry? @relation(fields: [journalId], references: [id])
  isActive   Boolean       @default(true)
  isDeleted  Boolean       @default(false)
  deletedAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime?
  createBy   String?
  updateBy   String?
}

model AccountBalance {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  period    DateTime // bisa bulanan
  debit     Decimal   @default(0.0)
  credit    Decimal   @default(0.0)
  balance   Decimal   @default(0.0)
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime?
  createBy  String?
  updateBy  String?
}

model TypeTransaction {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name           String
  journalEntry   JournalEntry[]
  debitAccountId String
  debitAccount   Account        @relation("DebitAccount", fields: [debitAccountId], references: [id])

  creditAccountId String
  creditAccount   Account @relation("CreditAccount", fields: [creditAccountId], references: [id])

  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime?
  createBy  String?
  updateBy  String?
}

model BusinessPartner {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id])
  name      String
  type      PartnerType // CUSTOMER, SUPPLIER, BOTH
  email     String?
  phone     String?
  address   String?

  taxId    String? // NPWP misalnya
  isActive Boolean @default(true)

  // Relasi ke transaksi/jurnal
  journalEntry JournalEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PartnerType {
  CUSTOMER
  SUPPLIER
  BOTH
}

model ProgramPaket {
  id          Int            @id @default(autoincrement())
  kode        String         @unique
  nama        String
  target      String?
  satuan      String?
  lokasi      String?
  jenisPaket  String?
  metode      String?
  sumberDana  String?
  parentId    Int?
  parent      ProgramPaket?  @relation("ProgramHierarchy", fields: [parentId], references: [id])
  children    ProgramPaket[] @relation("ProgramHierarchy")
  pagu        Decimal        @default(0)
  realisasi   Decimal        @default(0)
  blokir      Decimal        @default(0)
  keu         Decimal        @default(0)
  fisik       Decimal        @default(0)
  thang       Int            @default(2025)
  paket       Paket[]
  paketRkakl  PaketRkakl[]
  unitKerjaId Int?
  unitKerja   UnitKerja?     @relation(fields: [unitKerjaId], references: [id])
}

model Paket {
  id               Int          @id @default(autoincrement())
  thang            Int          @default(2025)
  programPaketKode String // FK ke ProgramPaket.kode
  programPaket     ProgramPaket @relation(fields: [programPaketKode], references: [kode])
  kdunit           String?
  kdsatker         String?
  kdprogram        String?
  kdgiat           String?
  kdoutput         String?
  kdsoutput        String?
  kdkmpnen         String?
  kdskmpnen        String?
  nmpaket          String?
  kdlokasi         String?
  kdkabkota        String?
  metode           String?
  kdpengadaan      String?

  vol         Int?
  sat         String?
  tgl_mulai   DateTime?
  tgl_selesai DateTime?

  // Pagu
  pagu_51    Decimal @default(0)
  pagu_52    Decimal @default(0)
  pagu_53    Decimal @default(0)
  pagu_rpm   Decimal @default(0)
  pagu_sbsn  Decimal @default(0)
  pagu_phln  Decimal @default(0)
  pagu_total Decimal @default(0)

  // Realisasi
  real_51    Decimal @default(0)
  real_52    Decimal @default(0)
  real_53    Decimal @default(0)
  real_rpm   Decimal @default(0)
  real_sbsn  Decimal @default(0)
  real_phln  Decimal @default(0)
  real_total Decimal @default(0)

  // Progres total
  progres_keuangan Decimal @default(0)
  progres_fisik    Decimal @default(0)

  // Progres keuangan bulanan
  progres_keu_jan Decimal @default(0)
  progres_keu_feb Decimal @default(0)
  progres_keu_mar Decimal @default(0)
  progres_keu_apr Decimal @default(0)
  progres_keu_mei Decimal @default(0)
  progres_keu_jun Decimal @default(0)
  progres_keu_jul Decimal @default(0)
  progres_keu_agu Decimal @default(0)
  progres_keu_sep Decimal @default(0)
  progres_keu_okt Decimal @default(0)
  progres_keu_nov Decimal @default(0)
  progres_keu_des Decimal @default(0)

  // Progres fisik bulanan
  progres_fisik_jan Decimal @default(0)
  progres_fisik_feb Decimal @default(0)
  progres_fisik_mar Decimal @default(0)
