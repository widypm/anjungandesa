// ==========================================
// MASTER WILAYAH
// ==========================================
model Provinsi {
  id   String @id
  nama String
  kota Kota[]

  // Relasi balik ke KLG
  klgKtp      Klg[] @relation("KtpProvinsi")
  klgDomisili Klg[] @relation("DomisiliProvinsi")

  @@map("provinsi")
}

model Kota {
  id         String      @id
  nama       String
  provinsiId String
  provinsi   Provinsi    @relation(fields: [provinsiId], references: [id])
  kecamatan  Kecamatan[]

  // Relasi balik ke KLG
  klgKtp      Klg[] @relation("KtpKota")
  klgDomisili Klg[] @relation("DomisiliKota")

  @@map("kota")
}

model Kecamatan {
  id        String      @id
  nama      String
  kotaId    String
  kota      Kota        @relation(fields: [kotaId], references: [id])
  kelurahan Kelurahan[]

  // Relasi balik ke KLG
  klgKtp      Klg[] @relation("KtpKecamatan")
  klgDomisili Klg[] @relation("DomisiliKecamatan")

  @@map("kecamatan")
}

model Kelurahan {
  id          String    @id
  nama        String
  kecamatanId String
  kecamatan   Kecamatan @relation(fields: [kecamatanId], references: [id])

  // Relasi balik ke KLG
  wargaKtp      Klg[] @relation("KtpKelurahan")
  wargaDomisili Klg[] @relation("DomisiliKelurahan")

  @@map("kelurahan")
}

// ==========================================
// DATA KLG
// ==========================================
model Klg {
  id           String   @id @default(uuid())
  nik          String   @unique
  nama         String
  jenisKelamin String
  tempatLahir  String
  tanggalLahir DateTime

  // Relasi alamat KTP
  ktpProvId String
  ktpProv   Provinsi  @relation("KtpProvinsi", fields: [ktpProvId], references: [id])
  ktpKotaId String
  ktpKota   Kota      @relation("KtpKota", fields: [ktpKotaId], references: [id])
  ktpKecId  String
  ktpKec    Kecamatan @relation("KtpKecamatan", fields: [ktpKecId], references: [id])
  ktpKelId  String
  ktpKel    Kelurahan @relation("KtpKelurahan", fields: [ktpKelId], references: [id])

  ktpRt     String?
  ktpRw     String?
  ktpAlamat String

  // Relasi alamat domisili
  domisiliProvId String?
  domisiliProv   Provinsi?  @relation("DomisiliProvinsi", fields: [domisiliProvId], references: [id])
  domisiliKotaId String?
  domisiliKota   Kota?      @relation("DomisiliKota", fields: [domisiliKotaId], references: [id])
  domisiliKecId  String?
  domisiliKec    Kecamatan? @relation("DomisiliKecamatan", fields: [domisiliKecId], references: [id])
  domisiliKelId  String?
  domisiliKel    Kelurahan? @relation("DomisiliKelurahan", fields: [domisiliKelId], references: [id])

  domisiliRt     String?
  domisiliRw     String?
  domisiliAlamat String?

  fotoKtp      String?
  fotoPasPhoto String?
  fotoPasKk    String?
  berkas1      String?
  berkas2      String?
  berkas3      String?
  berkas4      String?
  berkas5      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi status
  statusId String
  status   KlgStatus @relation(fields: [statusId], references: [id])

  // Relasi ptoLokasi
  ptoLokasiId String?
  lokasiPto   PtoLokasi? @relation(fields: [ptoLokasiId], references: [id])

  //Relasi Pto
  ptoId String?
  Pto   Pto?    @relation(fields: [ptoId], references: [id])

  //Relasi kelurahan
  lokasiKelurahan Int? //1=ktp 2=domisili
  //KlgKategory
  kategoryId      String
  kategory        KlgKategory @relation(fields: [kategoryId], references: [id])

  // Log status perubahan
  statusLogs KlgStatusLog[]

  reKlgs ReKlg[]

  sandi   String?
  oldData Int //0 lama 1 baru

  @@map("klg")
}

model KlgStatus {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  color       String?
  description String?
  order       Int?
  klg         Klg[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relasi dua arah ke log
  oldStatusLogs KlgStatusLog[] @relation("OldStatus")
  newStatusLogs KlgStatusLog[] @relation("NewStatus")
}

model KlgKategory {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  order       Int?
  fileA       String?
  fileB       String?
  fileC       String?
  fileD       String?
  logo        String?
  klg         Klg[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
}

model KlgStatusLog {
  id          String   @id @default(uuid())
  klgId       String // 🔹 disesuaikan dengan Klg.id
  oldStatusId String?
  newStatusId String
  changedBy   String?
  note        String?
  createdAt   DateTime @default(now())

  klg       Klg        @relation(fields: [klgId], references: [id])
  oldStatus KlgStatus? @relation("OldStatus", fields: [oldStatusId], references: [id])
  newStatus KlgStatus  @relation("NewStatus", fields: [newStatusId], references: [id])
}

model Pto {
  id        String                 @id @default(uuid())
  name      String
  status    Int
  ptoLokasi PtoLokasi[]
  klg       Klg[]
  ptoAssign PtoAssignmentCounter[]
  reKlgs    ReKlg[]
}

model PtoAssignmentCounter {
  id        String   @id @default(uuid())
  lastPtoId String?
  updatedAt DateTime @updatedAt

  // relasi opsional ke PTO
  lastPto Pto? @relation(fields: [lastPtoId], references: [id])
}

model PtoLokasi {
  id     String  @id @default(uuid())
  name   String
  status Int
  klg    Klg[]
  reKlgs ReKlg[]
  ptoId  String
  pto    Pto     @relation(fields: [ptoId], references: [id])
}

enum StatusReKlg {
  Request
  Reject
  Approve
}

enum TypeReKlg {
  Hilang
  Rusak
  Perpanjang
}

model ReKlg {
  id          String     @id @default(uuid())
  type        TypeReKlg
  klgId       String
  klg         Klg        @relation(fields: [klgId], references: [id])
  // Relasi ptoLokasi
  ptoLokasiId String?
  lokasiPto   PtoLokasi? @relation(fields: [ptoLokasiId], references: [id])

  fotoKartuRusak  String?
  fotoSuratHilang String?
  berkas1         String?
  berkas2         String?
  berkas3         String?
  berkas4         String?
  berkas5         String?

  status StatusReKlg
  ptoId  String
  pto    Pto         @relation(fields: [ptoId], references: [id])

  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Surat {
  id String @id @default(cuid())

  // ================= IDENTITAS =================
  jenis     String // domisili | ktp | lahir | kematian | usaha | dll
  nik       String?
  nama      String?
  ttl       String?
  alamat    String?
  pekerjaan String?

  // ================= TANAH =================
  letakTanah      String?
  luas            String?
  batasUtara      String?
  batasSelatan    String?
  batasTimur      String?
  batasBarat      String?
  statusTanah     String?
  penggunaanTanah String?

  // ================= USAHA =================
  namaUsaha   String?
  jenisUsaha  String?
  alamatUsaha String?
  lamaUsaha   String?

  // ================= KEMATIAN =================
  htlMeninggal   String?
  ttlMeninggal   String?
  sebabMeninggal String?

  // ================= PINDAH =================
  noKK         String?
  alamatAsal   String?
  alamatTujuan String?
  alasanPindah String?
  tglPindah    String?

  // ================= LAHIR =================
  ttlAnak   String?
  ttlAnakKe String?
  namaAyah  String?
  namaIbu   String?

  // ================= BEASISWA / BPJS =================
  sekolah     String?
  kelas       String?
  keperluan   String?
  diagnosa    String?
  faskes      String?
  noBpjs      String?
  namaSekolah String?

  // ================= HIBAH / JUAL BELI TANAH =================
  namaPenjual      String?
  namaPembeli      String?
  jenisTransaksi   String?
  nilaiTransaksi   String?
  namaPihakPertama String?
  nikPihakPertama  String?
  namaPihakKedua   String?
  nikPihakKedua    String?
  ahliWaris        Json?

  // ================= META =================
  status    StatusSurat @default(SUBMIT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([jenis])
}

enum StatusSurat {
  DRAFT
  SUBMIT
  APPROVED
  REJECTED
}
